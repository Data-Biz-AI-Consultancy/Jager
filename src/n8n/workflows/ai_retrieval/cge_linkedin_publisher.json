          }
        ]
      ]
    },
    "Post to Zernio": {
      "main": [
        [
          {
            "node": "Update DB on Success (Data Biz)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Update DB on Success (Data Biz)": {
