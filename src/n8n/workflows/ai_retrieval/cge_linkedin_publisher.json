        "postgres": {
          "id": "postgres-db",
          "name": "postgres Credential"
        }
      }
    },
    {
      "parameters": {
        "url": "https://zernio.com/api/v1/accounts",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {}
          ]
        },
        "options": {}
      },
      "id": "fetch-zernio-accounts",
      "name": "Fetch Zernio Accounts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        800,
        450
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "zernio-api-cred",
          "name": "Zernio API Credential"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet duePost = $('Fetch Due Posts').all().find(p => p.json && p.json.channel === 'databiz')?.json;\nif (!duePost) {\n  duePost = $('Fetch Due Posts').first()?.json;\n}\nif (!duePost) {\n  throw new Error(\"No posts found in 'Fetch Due Posts' output.\");\n}\n\nfunction extractAccounts(data) {\n  if (Array.isArray(data)) return data;\n  if (data && typeof data === 'object') {\n    if (data.platform) return [data];\n    for (const key of ['data', 'accounts', 'results', 'items']) {\n      if (Array.isArray(data[key])) return data[key];\n    }\n    for (const value of Object.values(data)) {\n      if (Array.isArray(value)) return value;\n    }\n  }\n  return [];\n}\n\nconst allRawAccounts = [];\nfor (const item of items) {\n  allRawAccounts.push(...extractAccounts(item.json));\n}\n\nconst linkedinAccounts = allRawAccounts.filter(acc => \n  acc.platform && acc.platform.toLowerCase() === 'linkedin'\n);\n\nif (linkedinAccounts.length === 0) {\n  throw new Error(\"No LinkedIn accounts found connected to Zernio. Connected platforms: \" + \n    allRawAccounts.map(a => `${a.platform || 'unknown'} (${a.id || a.accountId || 'no-id'})`).join(', ')\n  );\n}\n\nlet targetAccount = linkedinAccounts.find(acc => \n  acc.metadata && \n  (acc.metadata.accountType === 'organization' || acc.metadata.accountType === 'company')\n);\n\nif (!targetAccount) {\n  if (linkedinAccounts.length === 1) {\n    targetAccount = linkedinAccounts[0];\n  } else {\n    throw new Error(\"Multiple LinkedIn accounts found, but none are labeled as 'organization' or 'company'. \" +\n      \"Available LinkedIn accounts: \" + \n      linkedinAccounts.map(a => `${a.name || a.username || 'unnamed'} (ID: ${a.accountId || a.id || 'no-id'}, Type: ${a.metadata?.accountType || 'unknown'})`).join(', ')\n    );\n  }\n}\n\nconst accountId = targetAccount.accountId || targetAccount.id || targetAccount._id || targetAccount.account_id;\nif (!accountId) {\n  throw new Error(\"Resolved target account, but it has no accountId, id, _id, or account_id. Account details: \" + JSON.stringify(targetAccount));\n}\n\nif (typeof duePost.content !== 'string' || !duePost.content) {\n  throw new Error(\"duePost.content is missing or not a string. duePost keys: \" + Object.keys(duePost).join(', ') + \", duePost JSON: \" + JSON.stringify(duePost));\n}\n\nreturn [{ json: { \n  accountId: accountId,\n  content: duePost.content,\n  post_id: duePost.id\n} }];"
      },
      "id": "resolve-account-id",
      "name": "Resolve Account ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1000,
